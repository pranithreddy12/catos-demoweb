# Production edge for LunaCat: serves the built SPA and proxies /api to the
# backend, with automatic HTTPS. SITE_ADDRESS is injected at runtime:
#   - a domain (e.g. app.lunacat.co) -> Caddy auto-provisions a Let's Encrypt cert
#   - ":80" -> plain HTTP, for a quick no-domain smoke test
{$SITE_ADDRESS} {
	encode gzip zstd

	# Security headers. HSTS is added automatically by Caddy on HTTPS. The CSP was
	# verified against the production bundle (app loads, fonts/styles render, and
	# Firebase email/password login works) — 'unsafe-inline' is needed only for
	# styles (the app uses inline style={}), scripts stay strict 'self'.
	# img https: allows merchant product images; connect *.googleapis.com is Firebase.
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(self), microphone=(), geolocation=()"
		Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com; worker-src 'self' blob:; manifest-src 'self'; frame-src 'self'; frame-ancestors 'none'; object-src 'none'; base-uri 'self'; form-action 'self'"
		-Server
	}

	# API calls. handle_path strips the /api prefix, so /api/health -> backend /health
	# (the same rewrite the dev Vite proxy does). Backend is internal-only.
	handle_path /api/* {
		reverse_proxy backend:8009
	}

	# Everything else is the static SPA. try_files falls back to index.html so
	# client-side routes (/shop, /care, …) resolve; the service worker, manifest
	# and hashed assets are served directly.
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
